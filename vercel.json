{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "regions": ["bom1"],
    "services": {
        "app": {
            "root": ".",
            "entrypoint": "Dockerfile.vercel"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": {
                "service": "app"
            }
        }
    ]
}
